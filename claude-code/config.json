{
  "name": "Claude Code Terminal",
  "description": "Claude Code CLI with web terminal access and full config management",
  "version": "1.0.0",
  "slug": "claude_code",
  "url": "https://github.com/nateober/ha-claude-code-addon",
  "stage": "experimental",
  "init": false,
  "arch": ["aarch64", "amd64"],
  "homeassistant_api": true,
  "hassio_api": true,
  "ingress": true,
  "ingress_port": 7681,
  "panel_icon": "mdi:console",
  "panel_title": "Claude Code",
  "startup": "application",
  "map": ["config:rw", "ssl:ro", "addons:ro", "backup:rw", "share:rw"],
  "options": {
    "anthropic_api_key": ""
  },
  "schema": {
    "anthropic_api_key": "str?"
  },
  "environment": {
    "TERM": "xterm-256color"
  }
}
